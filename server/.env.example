# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# JWT_SECRET: Recommended so logins stay valid across backend restarts.
# Required in production. Use at least 32 random characters.
JWT_SECRET="replace_with_a_long_random_secret_at_least_32_chars"

# DATA_ENCRYPTION_SECRET: Required in production if JWT_SECRET should not also encrypt stored API keys.
# Use at least 32 random characters and keep it stable between deployments.
DATA_ENCRYPTION_SECRET="replace_with_a_long_random_secret_at_least_32_chars"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Optional comma-separated production frontend origins. APP_URL is also allowed.
CORS_ORIGINS="https://your-production-domain.example"

# Jira Ticketing Integration
JIRA_DOMAIN=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# MongoDB Integration
MONGODB_URI="your_mongodb_connection_string_here"
